generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                  Int                  @id @default(autoincrement())
  name                String
  email               String               @unique
  password            String
  role                Role                 @default(STAFF)
  department          Department
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  documents           Document[]
  procurementRequests ProcurementRequest[] @relation("RequestedBy")
  approvedRequests    ProcurementRequest[] @relation("ApprovedBy")
  activityLogs        ActivityLog[]
  auditLogs           AuditLog[]

  @@map("users")
}

model Document {
  id          Int              @id @default(autoincrement())
  title       String
  category    DocumentCategory
  department  Department
  filePath    String
  fileSize    Int?
  description String?          @db.Text
  uploadedBy  Int
  uploader    User             @relation(fields: [uploadedBy], references: [id])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("documents")
}

model ProcurementRequest {
  id                 Int               @id @default(autoincrement())
  referenceNo        String            @unique
  itemDescription    String            @db.Text
  quantity           Int
  estimatedCost      Decimal           @db.Decimal(12, 2)
  department         Department
  justification      String            @db.Text
  supportingDocument String?
  status             ProcurementStatus @default(PENDING)
  deptHeadApproval   ApprovalStatus?
  deptHeadComment    String?
  gmApproval         ApprovalStatus?
  gmComment          String?
  requestedById      Int
  requestedBy        User              @relation("RequestedBy", fields: [requestedById], references: [id])
  approvedById       Int?
  approvedBy         User?             @relation("ApprovedBy", fields: [approvedById], references: [id])
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@map("procurement_requests")
}

model ActivityLog {
  id                  Int        @id @default(autoincrement())
  userId              Int
  user                User       @relation(fields: [userId], references: [id])
  department          Department
  logDate             DateTime
  activityDescription String     @db.Text
  hoursSpent          Float
  createdAt           DateTime   @default(now())

  @@map("activity_logs")
}

model AuditLog {
  id          Int         @id @default(autoincrement())
  userId      Int
  user        User        @relation(fields: [userId], references: [id])
  action      AuditAction
  module      String
  description String      @db.Text
  ipAddress   String?
  createdAt   DateTime    @default(now())

  @@map("audit_logs")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  GENERAL_MANAGER
  DEPARTMENT_HEAD
  STAFF
  IT_ADMINISTRATOR
  AUDITOR
}

enum Department {
  GENERAL_MANAGER_OFFICE
  FINANCE_AND_ADMINISTRATION
  ENGINEERING
  PILOTS
  OPERATIONS
}

enum DocumentCategory {
  POLICY
  REPORT
  MEMO
  CONTRACT
  FORM
  OTHER
}

enum ProcurementStatus {
  PENDING
  DEPT_HEAD_APPROVED
  APPROVED
  REJECTED
}

enum ApprovalStatus {
  APPROVED
  REJECTED
}

enum AuditAction {
  LOGIN
  LOGOUT
  DOCUMENT_UPLOAD
  DOCUMENT_DOWNLOAD
  DOCUMENT_DELETE
  PROCUREMENT_SUBMIT
  PROCUREMENT_APPROVE
  PROCUREMENT_REJECT
  LOG_ENTRY
  USER_CREATED
  USER_UPDATED
  USER_DEACTIVATED
}
